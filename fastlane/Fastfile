# YT-99 — sign the GameCI-produced Xcode project and ship it to TestFlight.
# Match-free: every credential comes from a GitHub Actions secret (see
# APPLE_SIGNING_SETUP.md), decoded to files by the workflow. No git cert repo,
# nothing committed. Auth uses an App Store Connect API key (no Apple ID / 2FA).

require 'fileutils'

default_platform(:ios)

# GameCI writes the Xcode project to build/iOS/iOS/Unity-iPhone.xcodeproj; the
# workflow sets IOS_BUILD_PATH to <workspace>/build/iOS. Scheme + target are both
# "Unity-iPhone".
XCODEPROJ = "#{ENV['IOS_BUILD_PATH']}/iOS/Unity-iPhone.xcodeproj"
CERT_PATH = "#{ENV['RUNNER_TEMP']}/dist.p12"
PROFILE_PATH = "#{ENV['RUNNER_TEMP']}/profile.mobileprovision"

platform :ios do
  desc "Sign the Unity Xcode project and upload it to TestFlight"
  lane :beta do
    # 1. App Store Connect API key — used both for the upload and for the build's
    #    -allowProvisioningUpdates. The .p8 is stored base64-encoded in the secret.
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: ENV.fetch("APP_STORE_CONNECT_P8_BASE64"),
      is_key_content_base64: true,
      in_house: false
    )

    # 2. Ephemeral CI keychain (creates + unlocks 'fastlane_tmp_keychain').
    setup_ci

    # 3. Import the Apple Distribution certificate (.p12) into that keychain.
    import_certificate(
      certificate_path: CERT_PATH,
      certificate_password: ENV.fetch("IOS_DIST_CERT_PASSWORD"),
      keychain_name: "fastlane_tmp_keychain",
      keychain_password: ""
    )

    # 4. Install the App Store provisioning profile where xcodebuild looks for it.
    #    YT-104: update_project_provisioning only PARSES the profile and edits the
    #    pbxproj — it never installs it. The archive therefore carried a
    #    PROVISIONING_PROFILE_SPECIFIER naming a profile Xcode had never seen, and
    #    failed with "No profile for team '...' matching '...' found".
    profile = FastlaneCore::ProvisioningProfile.parse(PROFILE_PATH)
    profile_name = profile["Name"]
    profile_uuid = profile["UUID"]

    # Everything below uses the name read out of the profile, not the secret. A
    # stale IOS_PROVISIONING_PROFILE_NAME was the other candidate cause of the same
    # opaque Xcode error; deriving from the file makes it can't-happen. Warn rather
    # than fail — the build is correct either way, but the secret wants tidying.
    expected_name = ENV.fetch("IOS_PROVISIONING_PROFILE_NAME").strip
    if profile_name != expected_name
      UI.important("IOS_PROVISIONING_PROFILE_NAME is #{expected_name.inspect} but the profile " \
                   "is actually named #{profile_name.inspect}. Using the profile's real name; " \
                   "update the secret to match.")
    end

    # Same check for the team, which is the other half of the failing lookup.
    profile_team = Array(profile["TeamIdentifier"]).first
    expected_team = ENV.fetch("APPLE_TEAM_ID").strip
    if profile_team != expected_team
      UI.user_error!("Profile #{profile_name.inspect} belongs to team #{profile_team.inspect}, " \
                     "but APPLE_TEAM_ID is #{expected_team.inspect}.")
    end

    # Xcode <16 reads ~/Library/MobileDevice/Provisioning Profiles; Xcode 16+ reads
    # ~/Library/Developer/Xcode/UserData/Provisioning Profiles. The runner tracks
    # latest-stable, so install to both and don't depend on which one it is today.
    UI.message("Installing provisioning profile #{profile_name.inspect} (#{profile_uuid})")
    [
      File.expand_path("~/Library/MobileDevice/Provisioning Profiles"),
      File.expand_path("~/Library/Developer/Xcode/UserData/Provisioning Profiles")
    ].each do |dir|
      FileUtils.mkdir_p(dir)
      FileUtils.cp(PROFILE_PATH, File.join(dir, "#{profile_uuid}.mobileprovision"))
    end

    # 5. Wire the profile into the project.
    update_project_provisioning(
      xcodeproj: XCODEPROJ,
      profile: PROFILE_PATH,
      target_filter: "Unity-iPhone",
      build_configuration: "Release",
      code_signing_identity: "Apple Distribution"
    )

    # 6. Force manual signing on the target.
    update_code_signing_settings(
      use_automatic_signing: false,
      path: XCODEPROJ,
      targets: "Unity-iPhone",
      team_id: expected_team,
      code_sign_identity: "Apple Distribution",
      profile_name: profile_name,
      profile_uuid: profile_uuid,
      bundle_identifier: ENV.fetch("IOS_BUNDLE_ID")
    )

    # 7. Marketing version + encryption flag, written straight into the shipping Info.plist.
    #
    # YT-158/159 — the visible marketing version (CFBundleShortVersionString) is
    # 0.<MILESTONE>.<BUILD>, so every TestFlight build reads a distinct, strictly-increasing
    # version on device. It used to be a flat 0.2.0, so every update looked identical to the last
    # and only the hidden CFBundleVersion timestamp changed.
    #
    #   * MILESTONE — the release-milestone minor, bumped by hand when a new milestone starts
    #     (weapon era = 2; this boss/enemies/boss-death/home-page/intro era = 3). Keep it in sync
    #     with BuildStamp.MilestoneVersion ("0.<MILESTONE>.0") in Assets/_Project/Code/Editor.
    #   * BUILD — this workflow run's number. github.run_number of ios-testflight tracks the #N
    #     shown in Actions exactly (run #24 == number 24), so run #25 → 0.3.25, then 0.3.26…
    #
    # This is stamped HERE, on the macOS runner, on purpose: the GameCI Unity build runs in a Linux
    # container that never sees GITHUB_RUN_NUMBER (YT-117), so the run number can only be applied
    # after Unity. Writing it last makes it the pin — it overrides whatever Unity baked, the same
    # role YT-139's constant played for the flat 0.2.0. CFBundleVersion is left untouched: it stays
    # the auto-incrementing yyMMddHHmm timestamp (BuildStamp.ComposeIosBuildNumber, YT-117) that
    # keeps each upload unique.
    milestone = 3
    run_no = ENV["GITHUB_RUN_NUMBER"].to_s.strip
    run_no = "0" if run_no.empty?   # a local `fastlane ios beta` with no run number → 0.3.0 floor
    marketing_version = "0.#{milestone}.#{run_no}"
    UI.message("Marketing version (CFBundleShortVersionString) → #{marketing_version}")

    update_info_plist(
      xcodeproj: XCODEPROJ,
      plist_path: "Info.plist",
      block: proc { |plist|
        plist["ITSAppUsesNonExemptEncryption"] = false
        plist["CFBundleShortVersionString"] = marketing_version
      }
    )

    # 8. Archive + export a signed, App-Store-method .ipa.
    build_app(
      project: XCODEPROJ,
      scheme: "Unity-iPhone",
      configuration: "Release",
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates",
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: expected_team,
        provisioningProfiles: {
          ENV.fetch("IOS_BUNDLE_ID") => profile_name
        }
      }
    )

    # 9. Ship to TestFlight, and WAIT for Apple to finish processing.
    #
    # YT-117: this used to pass skip_waiting_for_build_processing: true, which returns as soon as
    # the bytes are transferred. Apple validates asynchronously *after* that — a duplicate build
    # number, a bad entitlement or a missing-compliance hold is only reported during processing.
    # So the run went green ("Successfully uploaded the new binary") while Apple could still be
    # discarding the binary, and nobody could tell the difference from the log. Waiting costs ~7
    # minutes of macOS time and buys the difference between "uploaded" and "actually a build".
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: false
    )
  end
end
